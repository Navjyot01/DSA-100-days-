class Solution
{
    // Function to remove a loop in the linked list.
    public static bool removeLoop(Node head)
    {
        if (head == null || head.next == null)
            return false;

        Node slow = head;
        Node fast = head;

        // Detect loop
        while (fast != null && fast.next != null)
        {
            slow = slow.next;
            fast = fast.next.next;

            if (slow == fast)
            {
                slow = head;

                // If loop starts at head
                if (slow == fast)
                {
                    while (fast.next != slow)
                        fast = fast.next;
                }
                else
                {
                    while (slow.next != fast.next)
                    {
                        slow = slow.next;
                        fast = fast.next;
                    }
                }

                // Remove loop
                fast.next = null;
                return true;
            }
        }

        return false; // No loop
    }
}
