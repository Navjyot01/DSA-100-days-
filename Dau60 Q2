#include <stdlib.h>

int cameras = 0;

// Returns state of node
int dfs(struct TreeNode* root) {
    if (root == NULL) return 1; // null nodes are covered

    int left = dfs(root->left);
    int right = dfs(root->right);

    // If any child is NOT covered → place camera
    if (left == 2 || right == 2) {
        cameras++;
        return 0; // has camera
    }

    // If any child has camera → this node is covered
    if (left == 0 || right == 0) {
        return 1; // covered
    }

    // Otherwise → not covered
    return 2;
}

int minCameraCover(struct TreeNode* root) {
    if (dfs(root) == 2) {
        cameras++; // root not covered
    }
    return cameras;
}
