#include <stdio.h>

#define MAX 100

typedef struct {
    int x, y;
} Pair;

int orangesRotting(int** grid, int gridSize, int* gridColSize) {
    int rows = gridSize;
    int cols = gridColSize[0];
    
    Pair queue[MAX];
    int front = 0, rear = 0;
    
    int fresh = 0;
    
    // Directions: up, down, left, right
    int dirs[4][2] = {{-1,0},{1,0},{0,-1},{0,1}};
    
    // Initialize queue with rotten oranges & count fresh
    for (int i = 0; i < rows; i++) {
        for (int j = 0; j < cols; j++) {
            if (grid[i][j] == 2) {
                queue[rear++] = (Pair){i, j};
            } else if (grid[i][j] == 1) {
                fresh++;
            }
        }
    }
    
    if (fresh == 0) return 0;
    
    int minutes = 0;
    
    while (front < rear) {
        int size = rear - front;
        int infected = 0;
        
        for (int i = 0; i < size; i++) {
            Pair p = queue[front++];
            
            for (int d = 0; d < 4; d++) {
                int nx = p.x + dirs[d][0];
                int ny = p.y + dirs[d][1];
                
                if (nx >= 0 && ny >= 0 && nx < rows && ny < cols && grid[nx][ny] == 1) {
                    grid[nx][ny] = 2;
                    queue[rear++] = (Pair){nx, ny};
                    fresh--;
                    infected = 1;
                }
            }
        }
        
        if (infected) minutes++;
    }
    
    return fresh == 0 ? minutes : -1;
}
