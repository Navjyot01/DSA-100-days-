#include <stdio.h>
#include <limits.h>

int findCheapestPrice(int n, int** flights, int flightsSize, int* flightsColSize, int src, int dst, int k) {
    int INF = INT_MAX / 2;  // avoid overflow
    int dist[n];

    // Initialize distances
    for (int i = 0; i < n; i++) {
        dist[i] = INF;
    }
    dist[src] = 0;

    // Relax edges k+1 times
    for (int i = 0; i <= k; i++) {
        int temp[n];
        
        // Copy current distances
        for (int j = 0; j < n; j++) {
            temp[j] = dist[j];
        }

        // Relax all edges
        for (int j = 0; j < flightsSize; j++) {
            int u = flights[j][0];
            int v = flights[j][1];
            int price = flights[j][2];

            if (dist[u] == INF) continue;

            if (dist[u] + price < temp[v]) {
                temp[v] = dist[u] + price;
            }
        }

        // Update dist array
        for (int j = 0; j < n; j++) {
            dist[j] = temp[j];
        }
    }

    return dist[dst] == INF ? -1 : dist[dst];
}
