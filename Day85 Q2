int findMin(int* nums, int numsSize) {
    int left = 0;
    int right = numsSize - 1;

    while (left < right) {
        int mid = left + (right - left) / 2;

        // Minimum is in the right half
        if (nums[mid] > nums[right]) {
            left = mid + 1;
        }
        // Minimum is in the left half (including mid)
        else {
            right = mid;
        }
    }

    return nums[left];
}
